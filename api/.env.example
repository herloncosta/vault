# PostgreSQL (Docker: docker compose up -d)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vault?schema=public"
PORT=3000
JWT_SECRET="change-me-to-a-random-secret"
JWT_EXPIRES_IN="7d"

# CORS (comma-separated origins; use * to allow all)
CORS_ORIGIN=*

# Rate limiting (window in ms, max requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
