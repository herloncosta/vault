generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  OPERATOR
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name          String?
  role          Role     @default(OPERATOR)
  monthlyBudget Decimal  @default(5000) @db.Decimal(12, 2) @map("monthly_budget")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  refreshTokens      RefreshToken[]
  revokedTokens      RevokedToken[]
  accessLogs         AccessLog[]
  transactions       Transaction[]
  recurringExpenses   RecurringExpense[]
  installmentExpenses  InstallmentExpense[]
  categories         Category[]

  @@map("users")
}

model Category {
  id        String          @id @default(uuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  type      TransactionType
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@unique([userId, name, type])
  @@map("categories")
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("refresh_tokens")
}

model RevokedToken {
  id        String   @id @default(uuid())
  jti       String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@index([jti])
  @@map("revoked_tokens")
}

model AccessLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("access_logs")
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model Transaction {
  id            String            @id @default(uuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          TransactionType
  amount        Decimal           @db.Decimal(12, 2)
  description   String
  category      String?
  date          DateTime
  paymentMethod String?           @map("payment_method")
  status        TransactionStatus @default(COMPLETED)
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  @@map("transactions")
}

model RecurringExpense {
  id            String          @id @default(uuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          TransactionType @default(EXPENSE)
  amount        Decimal         @db.Decimal(12, 2)
  description   String
  category      String?
  paymentMethod String?         @map("payment_method")
  dayOfMonth    Int
  startDate     DateTime        @map("start_date")
  endDate       DateTime?       @map("end_date")
  active        Boolean         @default(true)
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  @@map("recurring_expenses")
}

enum InstallmentType {
  CREDIT_CARD
  CARNE
}

model InstallmentExpense {
  id               String         @id @default(uuid())
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  description      String
  totalAmount      Decimal        @db.Decimal(12, 2) @map("total_amount")
  installmentCount Int            @map("installment_count")
  type             InstallmentType
  category         String?
  firstDueDate     DateTime       @map("first_due_date")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  installments     Installment[]

  @@map("installment_expenses")
}

model Installment {
  id                  String   @id @default(uuid())
  installmentExpenseId String @map("installment_expense_id")
  installmentExpense  InstallmentExpense @relation(fields: [installmentExpenseId], references: [id], onDelete: Cascade)
  amount              Decimal  @db.Decimal(12, 2)
  installmentNumber   Int      @map("installment_number")
  dueDate             DateTime @map("due_date")
  paid                Boolean  @default(false)
  paidAt              DateTime? @map("paid_at")
  createdAt           DateTime @default(now()) @map("created_at")

  @@map("installments")
}
